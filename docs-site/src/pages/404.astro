---
const links = [
  { href: './', label: 'Overview' },
  { href: './guides/getting-started/', label: 'Getting Started' },
  { href: './cli/', label: 'CLI Overview' },
  { href: './configuration/', label: 'Configuration' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found | Hike Docs</title>
    <style>
      :root {
        color-scheme: dark light;
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
      }

      body {
        background: #0b1020;
        color: #f5f7ff;
        display: grid;
        margin: 0;
        min-height: 100vh;
        place-items: center;
      }

      main {
        max-width: 42rem;
        padding: 2rem;
      }

      a {
        color: #c4b5fd;
      }

      ul {
        line-height: 1.9;
        padding-left: 1.25rem;
      }
    </style>
  </head>
  <body>
    <main>
      <p>404</p>
      <h1>Page not found</h1>
      <p>
        The docs page you requested does not exist or has moved as part of the
        Astro/Starlight migration.
      </p>
      <ul>
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </main>
  </body>
</html>
